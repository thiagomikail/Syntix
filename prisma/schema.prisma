// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// NextAuth Standard Models
// ----------------------------------------------------------------------------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Syntix Specific Extensions
  role          String    @default("USER") // GUEST, USER, ADMIN
  createdAt     DateTime  @default(now())

  // Relations
  accounts Account[]
  sessions Session[]
  ideas    Idea[]
  votes    Vote[]
  comments Comment[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------------------------------------------
// Syntix Domain Models (PRD v2)
// ----------------------------------------------------------------------------

model Idea {
  id             String   @id @default(cuid())
  userId         String
  title          String?
  rawText        String
  status         String   @default("ideation") // "ideation" | "refinement" | "stresstest"
  isPublic       Boolean  @default(false)
  archetype      String?  // "cash_cow" | "cash_farm" | "new_meat" | "ozempics" | "dead_end"
  refinementJson Json?    // Expanded strategy roadmap (Inception analysis)
  irlJson        Json?    // IRL scores (6-axis radar + 3 detailed metrics)
  thesisText     String?
  thumbnailUrl   String?  // AI-generated Bloomberg-themed business thumbnail
  averageRating  Float?   // Cached average star rating (1-5)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes    Vote[]
  comments Comment[]
}

model Vote {
  id        String   @id @default(cuid())
  ideaId    String
  userId    String
  score     Int      // 1-5 stars
  createdAt DateTime @default(now())

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ideaId])
}

model Comment {
  id         String   @id @default(cuid())
  ideaId     String
  userId     String?  // null = anonymous comment
  authorName String?  // Display name for anonymous comments
  content    String
  createdAt  DateTime @default(now())

  idea Idea  @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}
